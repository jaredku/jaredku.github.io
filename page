<!DOCTYPE html>
<html>
<body style="background-color: #000; color: #0f0; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; overflow: hidden; font-family: monospace;">

  <pre id="d" style="font-size: 10px; line-height: 8px; font-weight: bold;"></pre>

  <script>
    (function () {
      const pre = document.getElementById('d');
      let A = 0, B = 0;

      const asciimation = () => {
        let b = [];
        let z = [];
        A += 0.07;
        B += 0.03;
        let cA = Math.cos(A), sA = Math.sin(A),
            cB = Math.cos(B), sB = Math.sin(B);

        // Initialize buffers
        for (let k = 0; k < 1760; k++) {
          b[k] = k % 80 == 79 ? "\n" : " ";
          z[k] = 0;
        }

        // Math for the rotating torus
        for (let j = 0; j < 6.28; j += 0.07) {
          let ct = Math.cos(j), st = Math.sin(j);
          for (let i = 0; i < 6.28; i += 0.02) {
            let sp = Math.sin(i), cp = Math.cos(i),
                h = ct + 2, // radius
                D = 1 / (sp * h * sA + st * cA + 5),
                t = sp * h * cA - st * sA;

            let x = Math.floor(40 + 30 * D * (cp * h * cB - t * sB)),
                y = Math.floor(12 + 15 * D * (cp * h * sB + t * cB)),
                o = x + 80 * y,
                N = Math.floor(8 * ((st * sA - sp * ct * cA) * cB - sp * ct * sA - st * cA - cp * ct * sB));

            if (y < 22 && y >= 0 && x >= 0 && x < 79 && D > z[o]) {
              z[o] = D;
              b[o] = ".,-~:;=!*#$@"[N > 0 ? N : 0];
            }
          }
        }
        pre.innerHTML = b.join("");
        requestAnimationFrame(asciimation);
      };

      asciimation();
    })();
  </script>
</body>
</html>
